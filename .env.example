# AI Research Radar - 配置文件示例
# 复制此文件为 .env 并填入你的配置

# ========== 运行模式 ==========
# 单模型模式 (single) 或多模型协作模式 (ensemble)
MODEL_MODE=single

# ========== 单模型配置（MODEL_MODE=single 时使用）==========
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-flash

# ========== 多模型协作配置（MODEL_MODE=ensemble 时使用）==========
# DeepSeek API
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# Kimi API
KIMI_API_KEY=
# Kimi 模型列表（按价格从低到高）：
#   - moonshot-v1-8k: 最短上下文 8k，**最便宜** ✅推荐
#   - moonshot-v1-32k: 32k 上下文
#   - moonshot-v1-128k: 128k 上下文
#   - kimi-k2.6: Kimi 最智能模型，支持视觉/视频/推理，256k 上下文
KIMI_MODEL=moonshot-v1-8k

# GLM API
GLM_API_KEY=
# GLM 模型列表:
#   - glm-5.1: 最新旗舰，Coding 能力对齐 Claude Opus 4.6，200K 上下文
#   - glm-5: 高智能基座，擅长 Agentic 长程规划与执行
#   - glm-4.7-flash: 免费模型，最新基座模型的普惠版本，推荐
#   - glm-4-flashx-250414: 高速低价，超快推理速度
GLM_MODEL=glm-4.7-flash

# 协作策略: voting（投票）, weighted（加权）, consensus（共识）
ENSEMBLE_STRATEGY=voting

# ========== 其他配置 ==========
# 时区（默认 Asia/Shanghai）
# RADAR_TIMEZONE=Asia/Shanghai

# 排名限制（默认 100）
# RADAR_RANK_LIMIT=100

# 报告条目上限（默认 35）
# RADAR_MAX_REPORT_ITEMS=35

# LLM 摘要预算（默认 12）
# OPENAI_SUMMARY_BUDGET=12
