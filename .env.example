# AI Research Radar environment example.
# For GitHub Actions, configure repository Secrets and Variables instead of committing secrets.
# For local-only runs, you may copy this file to .env; .env is ignored by git.

# Default mode: cheap daily single-model summaries.
# Set MODEL_MODE=role_pipeline manually only when you want the advanced multi-model workflow.
MODEL_MODE=single

# Single-model OpenAI-compatible provider.
# Recommended cheap defaults:
#   Kimi:     OPENAI_BASE_URL=https://api.moonshot.cn/v1      OPENAI_MODEL=moonshot-v1-8k
#   DeepSeek: OPENAI_BASE_URL=https://api.deepseek.com        OPENAI_MODEL=deepseek-v4-flash
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.moonshot.cn/v1
OPENAI_MODEL=moonshot-v1-8k

# Single-mode cost controls.
OPENAI_SUMMARY_BUDGET=3
MAX_LLM_ITEMS=5
MAX_EVIDENCE_CHARS=1600
MAX_OUTPUT_TOKENS=250
OPENAI_TIMEOUT_SECONDS=20
COST_GUARD_ENABLED=true
DAILY_LLM_BUDGET_RMB=1.0

# Fallback provider keys used only when OPENAI_API_KEY is empty.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k

GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4.7-flash

# Advanced role-pipeline controls. These matter only with MODEL_MODE=role_pipeline.
ROLE_PIPELINE_BUDGET=3
SINGLE_LLM_BUDGET=3
RULE_BASED_CRITIC=true
CRITIC_LLM_ENABLED=false

# Other optional settings.
RADAR_TIMEZONE=Asia/Shanghai
RADAR_RANK_LIMIT=0
RADAR_MAX_REPORT_ITEMS=35
